# Application
APP_NAME=patchguard
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# GitHub Integration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# LLM — OpenAI-compatible. Switch between local (Ollama) and free hosted (Groq) by changing these 3 vars.
# Local (free, private):  LLM_BASE_URL=http://localhost:11434/v1  |  LLM_API_KEY=ollama  |  LLM_MODEL=qwen2.5-coder:7b
# Groq  (free, fast):     LLM_BASE_URL=https://api.groq.com/openai/v1  |  LLM_API_KEY=gsk_...  |  LLM_MODEL=llama-3.1-8b-instant
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5-coder:7b

# JWT Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-generate-a-random-string

# PostgreSQL (Neon free tier)
# Get from: https://neon.tech → Connection strings → Pooled connection
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.neon.tech/patchguard?sslmode=require

# Redis (Upstash free tier — uses rediss:// for TLS)
# Get from: https://upstash.com → Database → REST API → Connection URL
REDIS_URL=rediss://default:password@host.upstash.io:6380

# MongoDB (local dev / Atlas free tier for prod)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=patchguard

# Kafka (local dev only — Render deployment uses Celery+Redis instead)
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PR_EVENTS=pr-events
KAFKA_TOPIC_REVIEW_RESULTS=review-results
KAFKA_CONSUMER_GROUP=patchguard-consumers

# API Server
HOST=0.0.0.0
PORT=8000

# OpenTelemetry (optional)
OTEL_SERVICE_NAME=patchguard
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14268/api/traces
